# Copy this file to ".env" and fill in what you need.
# Ollama works with no real key. Add ANTHROPIC_API_KEY to field a Claude seat.

# --- Ollama (local, free; key is ignored by Ollama but must be non-empty) ---
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama

# --- Anthropic / Claude (functional) ---
ANTHROPIC_API_KEY=

# --- Optional frontier providers (leave blank to auto-disable) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
GOOGLE_API_KEY=
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# --- Match defaults ---
JJK_DEFAULT_SEED=42
# Per-match call budget guard (0 = unlimited). Frontier seats can get expensive.
JJK_MAX_MODEL_CALLS=0
